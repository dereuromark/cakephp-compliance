parameters:
	level: 8
	paths:
		- src/
	bootstrapFiles:
		- tests/bootstrap.php
	ignoreErrors:
		- identifier: missingType.iterableValue
		- identifier: missingType.generics
		-
			message: '#Trait .+\\RequiresDualApprovalTrait is used zero times#'
			path: src/DualApproval/Traits/RequiresDualApprovalTrait.php
