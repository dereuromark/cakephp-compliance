{
    "name": "dereuromark/cakephp-compliance",
    "description": "DACH compliance primitives for CakePHP 5.x: GoBD retention, multi-tenant scoping, gap-free numbering, dual-approval workflows.",
    "type": "cakephp-plugin",
    "keywords": [
        "cakephp",
        "plugin",
        "dach",
        "compliance",
        "germany"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Mark Scherer",
            "homepage": "https://www.dereuromark.de"
        }
    ],
    "require": {
        "php": ">=8.3",
        "cakephp/cakephp": "^5.2.0"
    },
    "suggest": {
        "dereuromark/cakephp-audit-stash": "Required to use the HashChainAuditPersister; see docs/Gobd.md."
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.1",
        "php-collective/code-sniffer": "dev-master as 0.4.6",
        "phpstan/phpstan": "^2.0.0"
    },
    "autoload": {
        "psr-4": {
            "Compliance\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Compliance\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@test"
        ],
        "cs-check": "phpcs --colors --parallel=16",
        "cs-fix": "phpcbf --colors --parallel=16",
        "stan": "vendor/bin/phpstan analyze",
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
